# ---------------------------------------------------------------------------
# Supabase (required for the admin panel to read/write real data)
# ---------------------------------------------------------------------------
# Project URL, from Supabase dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://uwxhfwrtatuhekoxugop.supabase.co/rest/v1/
# Public anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — SERVER ONLY, never exposed to the browser. Used by API
# routes to perform privileged writes (bypasses Row Level Security).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Admin authentication
# ---------------------------------------------------------------------------
# Email the admin logs in with.
ADMIN_EMAIL=admin@omnishift.ai
# Bcrypt hash of the admin password. Generate with:
#   npm run hash-password -- "your-password"
ADMIN_PASSWORD_HASH=$2a$10$replace-with-generated-hash

# Random 32+ character secret used to sign session cookies (JWT).
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-string
